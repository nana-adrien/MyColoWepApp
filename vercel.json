{
  "version": 2,
  "buildCommand": "./gradlew webApp:wasmJsBrowserDistribution",
  "outputDirectory": "webApp/build/dist/wasmJs/productionExecutable",

  "framework": null,
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*).wasm",
      "headers": [
        {
          "key": "Content-Encoding",
          "value": "br"
        },
        {
          "key": "Content-Type",
          "value": "application/wasm"
        }
      ]
    },
    {
      "source": "/(.*).js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
  {
    "source": "/(.*)",
    "destination": "/index.html"
  }
]
}